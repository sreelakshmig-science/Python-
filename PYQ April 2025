# sin(x) series

        import math
        
        x_deg = float(input("Enter the value of x in degrees: "))
        n = int(input("Enter the number of terms: "))
        
        # Convert degrees to radians
        x = x_deg * (math.pi / 180)
        
        sine_val = 0
        for i in range(n):
            # The general term is ((-1)^i * x^(2i+1)) / (2i+1)!
            sign = (-1)**i
            power = 2 * i + 1
            term = sign * (x**power) / math.factorial(power)
            sine_val += term
        
        print(f"The value of sin({x_deg}) up to {n} terms is: {sine_val}")
        print(f"Actual value using math.sin: {math.sin(x)}")
